# DNSGuard Environment Configuration
# Copy this file to a new file named '.env' in the same directory, and fill in your details.

# Local database URL (replace YOUR_PASSWORD with your actual local postgres password)
# Example: DATABASE_URL=postgresql://postgres:password123@localhost/dnsguard
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost/dnsguard

# Secret key for Flask session cookie encryption
SECRET_KEY=dnsguard_super_secret_key_change_in_prod

# Cookie security settings (False for HTTP localhost, True for HTTPS production)
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
