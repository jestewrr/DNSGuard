{
  "manifest_version": 3,
  "name": "DNSGuard - Secure Web Monitoring",
  "version": "1.0",
  "description": "Monitors websites and blocks malicious domains before access.",
  "permissions": [
    "webRequest",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://dnsguard-backend.onrender.com/*",
        "http://127.0.0.1:5000/*",
        "http://localhost:5000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DNSGuard"
  },
  "icons": {
    "16": "imagelogo.png",
    "48": "imagelogo.png",
    "128": "imagelogo.png"
  }
}
